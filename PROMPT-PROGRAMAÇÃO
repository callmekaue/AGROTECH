###LOOP PRINCIPAL
def iniciar_sistema():
    print("\nSistema iniciado")
    dados = carregar_dados()
    while True:
        opcao = menu_principal()
        if opcao == "1":
            sensores = ler_sensores_simulado()
            dados["historico_sensores"].append(sensores)
            salvar_dados(dados)
            exibir_relatorio(sensores)
        elif opcao == "2":
            sensores = ler_sensores_manual()
            dados["historico_sensores"].append(sensores)
            salvar_dados(dados)
            exibir_relatorio(sensores)
        elif opcao == "0":
            print("Encerrando sistema.")
            break
else:
            print("Opção inválida.")
        time.sleep(1)
