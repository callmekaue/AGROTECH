def ler_sensores_simulado():
    return {
        "temperatura": round(random.uniform(18, 40), 1),
        "umidade_solo": round(random.uniform(10, 90), 1),
        "umidade_ar": round(random.uniform(20, 80), 1),
        "luminosidade": round(random.uniform(100, 1000), 0),
        "horario": datetime.now().strftime("%d/%m/%Y %H:%M")
    }
def ler_sensores_manual():
    print("\nDigite os valores dos sensores:")
    try:
        temperatura = float(input("Temperatura (°C): "))
        umidade_solo = float(input("Umidade do solo (%): "))
        umidade_ar = float(input("Umidade do ar (%): "))
        luminosidade = float(input("Luminosidade (lux): "))
        return {
            "temperatura": temperatura,
            "umidade_solo": umidade_solo,
            "umidade_ar": umidade_ar,
            "luminosidade": luminosidade,
            "horario": datetime.now().strftime("%d/%m/%Y %H:%M")
        }
    except ValueError:
        print("Valor inválido. Usando dados simulados.")
        return ler_sensores_simulado()
