def exibir_relatorio(sensores):
    estado_solo, _ = analisar_solo(sensores["umidade_solo"])
    estado_clima, _ = analisar_clima(sensores["temperatura"])
    recomendacao, acao = gerar_recomendacao(sensores)
    print("\n" + "=" * 50)
    print("RELATÓRIO DO CAMPO")
    print("=" * 50)
    print(f"Horário: {sensores['horario']}")
    print(f"Temperatura: {sensores['temperatura']}°C - {estado_clima}")
    print(f"Umidade do solo: {sensores['umidade_solo']}% - {estado_solo}")
    print(f"Umidade do ar: {sensores['umidade_ar']}%")
    print(f"Luminosidade: {sensores['luminosidade']} lux")
    print("-" * 50)
    print("RECOMENDAÇÃO:")
    print(recomendacao)
    print("=" * 50)
    return acao
