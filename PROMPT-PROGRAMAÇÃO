###ANÁLISE DO SOLO E CLIMA
--
def analisar_solo(umidade_solo):
    if umidade_solo < 30:
        return "SECO", "RISCO"
    elif umidade_solo <= 70:
        return "IDEAL", "BOM"
    else:
        return "ENCHARCADO", "RISCO"
def analisar_clima(temperatura):
    if temperatura > 35:
        return "MUITO QUENTE", "CRITICO"
    elif temperatura < 10:
        return "MUITO FRIO", "FRIO EXTREMO"
    elif temperatura <= 15:
        return "FRESCO", "ATENCAO"
    else:
        return "AGRADAVEL", "BOM"
def gerar_recomendacao(sensores):
    temperatura = sensores["temperatura"]
    umidade_solo = sensores["umidade_solo"]
    estado_solo, _ = analisar_solo(umidade_solo)
    if estado_solo == "SECO" and temperatura > 30:
        return (
            "O solo está seco e o calor está forte.\n"
            "Ligue a água agora por pelo menos 20 minutos.\n"
            "Risco de perda da plantação."
        ), "IRRIGAR_IMEDIATO"
    elif estado_solo == "SECO":
        return (
            "O solo está seco.\n"
            "Molhe as plantas em breve, por cerca de 15 minutos."
        ), "IRRIGAR_BREVE"
    elif estado_solo == "ENCHARCADO":
        return (
            "O solo está com muita água.\n"
            "Não irrigar agora."
        ), "NAO_IRRIGAR"
    else:
        return (
            "Tudo está em condição normal.\n"
            "Apenas continue monitorando."
        ), "OK"
