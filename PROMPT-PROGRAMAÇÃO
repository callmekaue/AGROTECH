###CONFIGURAÇÕES - arquivo onde os dados são guardados
--
ARQUIVO_DADOS = "dados_agricola.json"
--
###FUNÇÕES DE ARQUIVO (salvar e carregar dados)
--
def carregar_dados():
    """Carrega os dados salvos no arquivo JSON."""
    try:
        with open(ARQUIVO_DADOS, "r", encoding="utf-8") as f:
            return json.load(f)
    except FileNotFoundError:
        return {
            "tarefas": [],
            "historico_sensores": [],
            "historico_irrigacao": []
        }
    except json.JSONDecodeError:
        print("Arquivo de dados com problema. Começando novo arquivo.")
        return {
            "tarefas": [],
            "historico_sensores": [],
            "historico_irrigacao": []
        }
def salvar_dados(dados):
    """Salva os dados no arquivo JSON."""
    try:
        with open(ARQUIVO_DADOS, "w", encoding="utf-8") as f:
            json.dump(dados, f, ensure_ascii=False, indent=2)
        print("Dados salvos com sucesso!")
    except Exception as e:
        print(f"Não consegui salvar os dados: {e}")
